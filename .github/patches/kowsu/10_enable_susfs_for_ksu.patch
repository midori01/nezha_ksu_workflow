+// Under SUSFS, vol_detector_event handles input via input_handler framework.
+// This entry point is called directly from input.c and must exist under SUSFS.
+// Mirrors vol_detector_event exactly: only count key-DOWN events for volume keys.
+int ksu_handle_input_handle_event(unsigned int *type, unsigned int *code, int *value)
+{
+    if (!ksu_input_hook)
+        return 0;
+
+    // ignore key releases
+    if (!*value)
+        return 0;
+
+    if (*type != EV_KEY)
+        return 0;
+
+    // only volume keys trigger safe mode
+    if (*code != KEY_VOLUMEDOWN && *code != KEY_VOLUMEUP)
+        return 0;
+
+    if (*code == KEY_VOLUMEDOWN)
+        pr_info("KEY_VOLUMEDOWN press detected!\n");
+
+    if (*code == KEY_VOLUMEUP)
+        pr_info("KEY_VOLUMEUP press detected!\n");
+
+    volume_pressed_count++;
+    pr_info("volume_pressed_count: %d\n", volume_pressed_count);
+
+    return 0;
+}
+
